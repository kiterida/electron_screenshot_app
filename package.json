{
  "name": "electron-media-app",
   "description": "Electron app for managing media items",
  "author": "Kadoosh",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.1.0",
    "@mui/material": "^7.1.0",
    "@mui/x-data-grid": "^8.5.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "better-sqlite3": "^11.10.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-scripts": "^5.0.1",
    "sharp": "^0.34.2",
    "web-vitals": "^2.1.4"
  },
  "main": "main.js",
  "homepage": "./",
  "build": {
    "extends": null,
    "appId": "com.kadoosh.electronmediaapp",
    "productName": "Electron Media App",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "build/**/*",
      "main.js",
      "preload.js",
      "convertScreenshotsToJpeg.js"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "public"
    },
    "win": {
      "target": "nsis",
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Electron Media App"
    }
  },
  "scripts": {
    "start": "npm run build && set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "electron": "npm run build && set \"ELECTRON_RUN_AS_NODE=\" && electron .",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dist": "electron-builder"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "wait-on": "^7.2.0"
  }
}
